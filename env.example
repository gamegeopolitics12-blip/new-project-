# ═══════════════════════════════════════════════════════
# ODRkart Backend Environment Variables
# ═══════════════════════════════════════════════════════
# SECURITY WARNING: Never commit this file with real values!
# Copy to .env and fill with actual values
# ═══════════════════════════════════════════════════════

# Environment
NODE_ENV=development
PORT=5000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# ═══════════════════════════════════════════════════════
# DATABASE
# ═══════════════════════════════════════════════════════

# PostgreSQL Connection String
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://odrkart:password@localhost:5432/odrkart_db?schema=public

# ═══════════════════════════════════════════════════════
# REDIS (Caching & Rate Limiting)
# ═══════════════════════════════════════════════════════

REDIS_URL=redis://localhost:6379

# ═══════════════════════════════════════════════════════
# JWT SECRETS
# ═══════════════════════════════════════════════════════
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long-change-this
JWT_REFRESH_SECRET=your-super-secret-refresh-key-minimum-32-characters-long-change-this
COOKIE_SECRET=your-super-secret-cookie-key-minimum-32-characters-long-change-this

# ═══════════════════════════════════════════════════════
# STRIPE PAYMENT
# ═══════════════════════════════════════════════════════

# Get from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# Webhook secret from Stripe CLI or Dashboard
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ═══════════════════════════════════════════════════════
# ANTHROPIC (Claude API)
# ═══════════════════════════════════════════════════════

# Get from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-your-anthropic-api-key-here

# ═══════════════════════════════════════════════════════
# EMAIL (Nodemailer)
# ═══════════════════════════════════════════════════════

# SMTP Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=noreply@odrkart.com
EMAIL_PASSWORD=your-email-app-password

# Sender Details
EMAIL_FROM_NAME=ODRkart
EMAIL_FROM_ADDRESS=noreply@odrkart.com

# ═══════════════════════════════════════════════════════
# AWS S3 (File Storage)
# ═══════════════════════════════════════════════════════

AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=odrkart-documents
AWS_S3_ENCRYPTED=true

# ═══════════════════════════════════════════════════════
# MONITORING & LOGGING
# ═══════════════════════════════════════════════════════

# Winston Log Level: error, warn, info, http, verbose, debug, silly
LOG_LEVEL=info

# Sentry (Optional - for error tracking)
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ═══════════════════════════════════════════════════════
# VIDEO CONFERENCING (Optional)
# ═══════════════════════════════════════════════════════

# Zoom / Google Meet / Whereby API keys
ZOOM_API_KEY=your-zoom-api-key
ZOOM_API_SECRET=your-zoom-api-secret

# ═══════════════════════════════════════════════════════
# RATE LIMITING
# ═══════════════════════════════════════════════════════

# General API
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Authentication
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=5

# AI API
AI_RATE_LIMIT_WINDOW_MS=60000
AI_RATE_LIMIT_MAX=10

# ═══════════════════════════════════════════════════════
# SECURITY
# ═══════════════════════════════════════════════════════

# HTTPS (Production only)
SSL_CERT_PATH=/path/to/cert.pem
SSL_KEY_PATH=/path/to/key.pem

# Session
SESSION_LIFETIME=604800000

# CORS
CORS_ORIGIN=http://localhost:3000,https://odrkart.com

# ═══════════════════════════════════════════════════════
# FEATURE FLAGS
# ═══════════════════════════════════════════════════════

FEATURE_AI_LAB_BLOG=true
FEATURE_AI_DOCUMENT_ANALYSIS=true
FEATURE_VIDEO_HEARINGS=true
FEATURE_BLOCKCHAIN_EVIDENCE=false

# ═══════════════════════════════════════════════════════
# COMPLIANCE
# ═══════════════════════════════════════════════════════

# Data retention (days)
DATA_RETENTION_DAYS=2555

# Audit log retention (days)
AUDIT_LOG_RETENTION_DAYS=2555

# ═══════════════════════════════════════════════════════
# PRODUCTION CHECKLIST
# ═══════════════════════════════════════════════════════
# 
# □ Change all SECRET values
# □ Set NODE_ENV=production
# □ Use strong DATABASE_URL password
# □ Enable AWS_S3_ENCRYPTED=true
# □ Set up SSL certificates
# □ Configure SENTRY_DSN for error tracking
# □ Set CORS_ORIGIN to production domain only
# □ Enable rate limiting
# □ Set up automated backups
# □ Review and test all environment variables
# □ Never commit .env file to version control
#
# ═══════════════════════════════════════════════════════
